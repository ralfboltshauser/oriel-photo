{
  "name": "@oriel/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Oriel desktop photo workspace",
  "author": {
    "name": "Oriel contributors",
    "email": "ralfboltshauser@users.noreply.github.com"
  },
  "desktopName": "oriel",
  "homepage": "https://github.com/ralfboltshauser/oriel-photo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ralfboltshauser/oriel-photo.git"
  },
  "license": "AGPL-3.0-or-later",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:test": "vite --config vite.renderer.config.ts",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "pnpm test:e2e:browser && pnpm test:e2e:electron",
    "test:e2e:browser": "playwright test --project=browser --project=a11y",
    "test:e2e:electron": "pnpm build && node scripts/run-electron-e2e.mjs",
    "test:visual": "playwright test --project=visual",
    "test:visual:update": "playwright test --project=visual --update-snapshots",
    "test:a11y": "playwright test --project=a11y",
    "package:dir": "pnpm build && electron-builder --dir",
    "package:linux": "pnpm build && electron-builder --linux AppImage deb"
  },
  "dependencies": {
    "@fontsource-variable/geist": "5.2.9",
    "@oriel/domain": "workspace:*",
    "@oriel/fixtures": "workspace:*",
    "@oriel/ui": "workspace:*",
    "@radix-ui/react-dialog": "1.1.19",
    "cmdk": "1.1.1",
    "electron-log": "5.4.4",
    "lucide-react": "1.25.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sonner": "2.0.7",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "jsdom": "29.1.1",
    "playwright": "1.61.1",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
