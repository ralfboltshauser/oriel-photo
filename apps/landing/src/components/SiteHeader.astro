---
import BrandMark from './BrandMark.astro';

const repositoryUrl = 'https://github.com/ralfboltshauser/oriel-photo';
---

<header class="site-header" data-site-header>
  <div class="scroll-progress" aria-hidden="true"><span data-scroll-progress></span></div>
  <div class="header-inner">
    <a class="brand" href="#top" aria-label="Oriel home">
      <BrandMark size={30} />
      <span>Oriel</span>
      <small><i aria-hidden="true"></i>Alpha</small>
    </a>

    <nav aria-label="Primary navigation">
      <a href="#workflow">Workflow</a>
      <a href="#ownership">Ownership</a>
      <a href="#fit">Is it for me?</a>
    </nav>

    <a class="header-cta" href={repositoryUrl} target="_blank" rel="noreferrer">
      <svg aria-hidden="true" viewBox="0 0 24 24">
        <path
          d="M12 2.75a9.25 9.25 0 0 0-2.93 18.03c.46.08.63-.2.63-.44v-1.8c-2.57.56-3.11-1.09-3.11-1.09-.42-1.07-1.03-1.35-1.03-1.35-.84-.58.06-.57.06-.57.93.07 1.42.96 1.42.96.83 1.42 2.17 1.01 2.7.77.08-.6.32-1.01.59-1.25-2.05-.23-4.21-1.03-4.21-4.57 0-1.01.36-1.84.95-2.49-.1-.23-.41-1.17.09-2.45 0 0 .78-.25 2.54.95a8.8 8.8 0 0 1 4.62 0c1.76-1.2 2.54-.95 2.54-.95.5 1.28.19 2.22.09 2.45.59.65.95 1.48.95 2.49 0 3.55-2.16 4.33-4.22 4.56.33.29.63.86.63 1.73v2.66c0 .24.17.53.64.44A9.25 9.25 0 0 0 12 2.75Z"
          fill="currentColor"></path>
      </svg>
      <span>View source</span>
      <span class="arrow" aria-hidden="true">↗</span>
    </a>
  </div>
</header>

<style>
  .site-header {
    left: 0;
    padding: 14px 20px 0;
    pointer-events: none;
    position: fixed;
    right: 0;
    top: 0;
    z-index: 90;
  }

  .header-inner {
    align-items: center;
    background: color-mix(in srgb, var(--oriel-ink) 72%, transparent);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 12px;
    box-shadow:
      0 18px 48px rgba(0, 0, 0, 0.18),
      0 1px 0 rgba(255, 255, 255, 0.05) inset;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    height: 58px;
    margin: 0 auto;
    max-width: 1320px;
    padding: 0 9px 0 15px;
    pointer-events: auto;
    transition:
      background-color 220ms var(--oriel-ease-out),
      border-color 220ms var(--oriel-ease-out),
      box-shadow 220ms var(--oriel-ease-out),
      transform 220ms var(--oriel-ease-out);
  }

  .site-header[data-scrolled='true'] .header-inner {
    -webkit-backdrop-filter: blur(18px) saturate(135%);
    backdrop-filter: blur(18px) saturate(135%);
    background: color-mix(in srgb, var(--oriel-ink) 86%, transparent);
    border-color: rgba(255, 255, 255, 0.13);
    box-shadow:
      0 22px 64px rgba(0, 0, 0, 0.32),
      0 1px 0 rgba(255, 255, 255, 0.07) inset;
  }

  .brand {
    align-items: center;
    display: inline-flex;
    font-size: 15px;
    font-weight: 630;
    gap: 9px;
    justify-self: start;
    letter-spacing: -0.025em;
  }

  .brand small {
    align-items: center;
    border: 1px solid var(--oriel-divider);
    border-radius: 999px;
    color: var(--oriel-text-muted);
    display: inline-flex;
    font-size: 8px;
    font-weight: 670;
    gap: 5px;
    letter-spacing: 0.1em;
    margin-left: 4px;
    padding: 4px 7px;
    text-transform: uppercase;
  }

  .brand i {
    background: var(--oriel-success);
    border-radius: 50%;
    box-shadow: 0 0 0 3px rgba(112, 211, 154, 0.11);
    height: 4px;
    width: 4px;
  }

  nav {
    align-items: center;
    display: flex;
    gap: 6px;
    justify-content: center;
  }

  nav a {
    border-radius: 7px;
    color: var(--oriel-text-secondary);
    font-size: 11px;
    padding: 9px 12px;
    transition:
      background-color 140ms ease,
      color 140ms ease;
  }

  .header-cta {
    align-items: center;
    background: var(--oriel-text);
    border-radius: 7px;
    color: var(--oriel-ink);
    display: inline-flex;
    font-size: 11px;
    font-weight: 620;
    gap: 7px;
    height: 40px;
    justify-self: end;
    padding: 0 12px;
    transition:
      background-color 140ms ease,
      transform 130ms var(--oriel-ease-out);
  }

  .header-cta svg {
    height: 15px;
    width: 15px;
  }

  .header-cta .arrow {
    color: #6f756f;
    font-size: 12px;
  }

  .header-cta:active {
    transform: scale(0.97);
  }

  .scroll-progress {
    background: transparent;
    height: 1px;
    left: 0;
    overflow: hidden;
    position: fixed;
    right: 0;
    top: 0;
  }

  .scroll-progress span {
    background: var(--oriel-coral);
    display: block;
    height: 100%;
    transform: scaleX(0);
    transform-origin: left;
    width: 100%;
  }

  @media (hover: hover) and (pointer: fine) {
    nav a:hover {
      background: rgba(255, 255, 255, 0.055);
      color: var(--oriel-text);
    }

    .header-cta:hover {
      background: #ffffff;
    }
  }

  @media (max-width: 760px) {
    .site-header {
      padding: 10px 10px 0;
    }

    .header-inner {
      display: flex;
      height: 54px;
      justify-content: space-between;
      padding-left: 12px;
    }

    nav,
    .brand small,
    .header-cta svg {
      display: none;
    }

    .header-cta {
      height: 38px;
    }
  }

  @media (prefers-reduced-transparency: reduce) {
    .site-header[data-scrolled='true'] .header-inner {
      -webkit-backdrop-filter: none;
      backdrop-filter: none;
      background: var(--oriel-ink);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .header-inner,
    .header-cta,
    nav a {
      transition-duration: 0.01ms;
    }
  }
</style>
