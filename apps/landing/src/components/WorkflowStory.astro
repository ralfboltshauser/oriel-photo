---
import deliveryImage from '../../../desktop/tests/e2e/__screenshots__/visual/06-export.png';
import editImage from '../../../desktop/tests/e2e/__screenshots__/visual/04-edit.png';
import libraryImage from '../../../desktop/tests/e2e/__screenshots__/visual/03-library.png';
import selectImage from '../../../desktop/tests/e2e/__screenshots__/visual/03-select.png';
import ProductFrame from './ProductFrame.astro';

const stages = [
  {
    id: 'library',
    number: '01',
    name: 'Library',
    title: 'Know what enters.',
    description:
      'Open a folder and review what Oriel can read before you confirm. Supported photographs are referenced in place; originals never move.',
    facts: ['Review before confirm', 'Referenced in place'],
    image: libraryImage,
    alt: 'Oriel Library workspace showing a twelve-photo Alpine weekend folder, a photograph grid, picks and ratings, and local workspace status.',
  },
  {
    id: 'select',
    number: '02',
    name: 'Select',
    title: 'Decide without breaking rhythm.',
    description:
      'Pick, reject, and rate from the keyboard while one photograph stays in view. Hold Shift to decide and advance to the next frame.',
    facts: ['P · X · U', '0–5 ratings', 'Shift to advance'],
    image: selectImage,
    alt: 'Oriel Select workspace showing one large photograph, pick and rating controls, a filmstrip, and keyboard shortcut guidance.',
  },
  {
    id: 'edit',
    number: '03',
    name: 'Edit',
    title: 'Shape the keeper.',
    description:
      'Begin with essential light and color, then reveal more only when it is useful. Compare the original and create versions without duplicating the source.',
    facts: ['Light and color', 'Reversible versions', 'Original preview'],
    image: editImage,
    alt: 'Oriel Edit workspace showing a photograph with essential light and color controls, versions, crop choices, and a filmstrip.',
  },
  {
    id: 'deliver',
    number: '04',
    name: 'Deliver',
    title: 'Export with the ending in view.',
    description:
      'Choose the exact set, JPEG recipe, and destination before rendering. Existing names receive numbered copies; originals remain untouched.',
    facts: ['Selection or picks', 'Two JPEG recipes', 'Collision-safe names'],
    image: deliveryImage,
    alt: 'Oriel export dialog showing two picked photographs, Web JPEG and full-size recipes, a destination choice, and an original-file safety message.',
  },
];
---

<section
  class="workflow-story"
  id="workflow"
  aria-labelledby="workflow-story-title"
  data-workflow-story
>
  <header class="story-intro">
    <p class="story-eyebrow">ONE COHERENT PATH</p>
    <div>
      <h2 id="workflow-story-title">One shoot.<br />Four rooms.</h2>
      <p>
        The stage stays stable while the work changes. Every step has one clear purpose and a
        visible ending.
      </p>
    </div>
  </header>

  <div class="story-layout">
    <div class="story-steps">
      {
        stages.map((stage, index) => (
          <article
            class="story-step"
            data-workflow-step
            data-stage={stage.id}
            data-active={index === 0 ? 'true' : 'false'}
            aria-current={index === 0 ? 'step' : undefined}
          >
            <div class="step-heading">
              <span class="step-number">{stage.number}</span>
              <span class="step-name">{stage.name}</span>
            </div>
            <h3>{stage.title}</h3>
            <p>{stage.description}</p>
            <ul aria-label={`${stage.name} capabilities`}>
              {stage.facts.map((fact) => (
                <li>{fact}</li>
              ))}
            </ul>
            <div class="mobile-frame" data-workflow-mobile-frame>
              <ProductFrame image={stage.image} alt={stage.alt} label={stage.name} />
            </div>
          </article>
        ))
      }
    </div>

    <div class="sticky-visual" data-workflow-visual aria-label="The Oriel workflow in the app">
      <div class="visual-meta" aria-hidden="true">
        <span>Actual alpha interface</span>
        <span class="visual-line"></span>
        <span data-workflow-progress>01 / 04</span>
      </div>
      <div class="frame-stack">
        {
          stages.map((stage, index) => (
            <div
              class="workflow-frame"
              data-workflow-frame
              data-stage={stage.id}
              data-active={index === 0 ? 'true' : 'false'}
              aria-hidden={index === 0 ? 'false' : 'true'}
            >
              <ProductFrame
                image={stage.image}
                alt={stage.alt}
                label={stage.name}
                loading={index === 0 ? 'eager' : 'lazy'}
                priority={index === 0}
              />
            </div>
          ))
        }
      </div>
      <p class="visual-note">Captured from the tested desktop build.</p>
    </div>
  </div>
</section>

<style>
  .workflow-story {
    margin: 0 auto;
    max-width: 90rem;
    padding: clamp(7rem, 13vw, 12rem) clamp(1.25rem, 4vw, 3.5rem);
  }

  .story-intro {
    align-items: start;
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(10rem, 0.46fr) minmax(0, 1fr);
    margin-bottom: clamp(5rem, 10vw, 9rem);
  }

  .story-eyebrow {
    color: var(--oriel-coral);
    font-size: 0.65rem;
    font-weight: 680;
    letter-spacing: 0.16em;
    margin: 0.8rem 0 0;
  }

  .story-intro h2 {
    font-size: clamp(3.5rem, 7vw, 7rem);
    font-weight: 520;
    letter-spacing: -0.07em;
    line-height: 0.87;
    margin: 0;
    text-wrap: balance;
  }

  .story-intro div > p {
    color: var(--oriel-text-secondary);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    line-height: 1.6;
    margin: 2rem 0 0;
    max-width: 36rem;
  }

  .story-layout {
    display: grid;
    gap: clamp(3rem, 7vw, 7rem);
    grid-template-columns: minmax(18rem, 0.68fr) minmax(0, 1.5fr);
  }

  .story-step {
    border-left: 1px solid rgb(255 255 255 / 10%);
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: min(70rem, 78vh);
    padding: 3rem 0 3rem clamp(1.5rem, 3vw, 2.75rem);
    position: relative;
  }

  .story-step::before {
    background: var(--oriel-coral);
    content: '';
    height: 0;
    left: -1px;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    transition: height 240ms var(--oriel-ease-out);
    width: 1px;
  }

  .story-step[data-active='true']::before {
    height: 5.25rem;
  }

  .step-heading {
    align-items: center;
    color: var(--oriel-text-muted);
    display: flex;
    font-family: 'Geist Mono Variable', 'Geist Mono', monospace;
    font-size: 0.65rem;
    gap: 0.8rem;
    letter-spacing: 0.08em;
    margin-bottom: 1.35rem;
    text-transform: uppercase;
  }

  .step-number {
    color: var(--oriel-coral);
  }

  .story-step h3 {
    font-size: clamp(2.15rem, 4vw, 4rem);
    font-weight: 520;
    letter-spacing: -0.055em;
    line-height: 0.98;
    margin: 0;
    max-width: 10ch;
  }

  .story-step > p {
    color: var(--oriel-text-secondary);
    font-size: clamp(0.95rem, 1.3vw, 1.05rem);
    line-height: 1.65;
    margin: 1.5rem 0 0;
    max-width: 30rem;
  }

  .story-step ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    list-style: none;
    margin: 1.75rem 0 0;
    padding: 0;
  }

  .story-step li {
    background: rgb(255 255 255 / 3%);
    border: 1px solid rgb(255 255 255 / 10%);
    border-radius: 999px;
    color: var(--oriel-text-muted);
    font-size: 0.66rem;
    padding: 0.45rem 0.65rem;
  }

  .sticky-visual {
    align-self: start;
    min-width: 0;
    padding-top: 1rem;
    position: sticky;
    top: clamp(5rem, 11vh, 8rem);
  }

  .visual-meta {
    align-items: center;
    color: var(--oriel-text-muted);
    display: flex;
    font-family: 'Geist Mono Variable', 'Geist Mono', monospace;
    font-size: 0.58rem;
    gap: 0.8rem;
    letter-spacing: 0.08em;
    margin: 0 0 0.8rem;
    text-transform: uppercase;
  }

  .visual-line {
    background: rgb(255 255 255 / 12%);
    flex: 1;
    height: 1px;
  }

  .frame-stack {
    aspect-ratio: 1.44 / 1;
    position: relative;
  }

  .workflow-frame {
    inset: 0;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    transform: translateY(0.75rem) scale(0.992);
    transition:
      opacity 220ms var(--oriel-ease-out),
      transform 260ms var(--oriel-ease-out),
      visibility 0s linear 260ms;
    visibility: hidden;
  }

  .workflow-frame[data-active='true'] {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0) scale(1);
    transition-delay: 0s;
    visibility: visible;
  }

  .visual-note {
    color: var(--oriel-text-muted);
    font-size: 0.63rem;
    margin: 1rem 0 0;
    text-align: right;
  }

  .mobile-frame {
    display: none;
    margin-top: 2.5rem;
  }

  @media (max-width: 64rem) {
    .workflow-story {
      padding-inline: clamp(1.25rem, 5vw, 3rem);
    }

    .story-intro {
      display: block;
    }

    .story-eyebrow {
      margin: 0 0 1.5rem;
    }

    .story-layout {
      display: block;
    }

    .story-step {
      min-height: 0;
      padding-block: clamp(4rem, 11vw, 6rem);
    }

    .story-step + .story-step {
      margin-top: 1rem;
    }

    .sticky-visual {
      display: none;
    }

    .mobile-frame {
      display: block;
    }
  }

  @media (max-width: 36rem) {
    .workflow-story {
      padding-inline: 1.1rem;
    }

    .story-step {
      border-left: 0;
      padding-left: 0;
    }

    .story-step::before {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .story-layout {
      display: block;
    }

    .story-step {
      min-height: 0;
      padding-block: clamp(4rem, 8vw, 6rem);
    }

    .story-step::before,
    .workflow-frame {
      transition: none;
    }

    .sticky-visual {
      display: none;
    }

    .mobile-frame {
      display: block;
    }
  }
</style>
