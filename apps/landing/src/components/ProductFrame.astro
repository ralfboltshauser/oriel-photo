---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  image: ImageMetadata;
  alt: string;
  loading?: 'eager' | 'lazy';
  priority?: boolean;
  class?: string;
  label?: string;
}

const {
  image,
  alt,
  loading = 'lazy',
  priority = false,
  class: className,
  label = 'Oriel workspace',
} = Astro.props;

const effectiveLoading = priority ? 'eager' : loading;
---

<figure class:list={['product-frame', className]} data-product-frame>
  <div class="frame-atmosphere" aria-hidden="true"></div>
  <div class="frame-shell">
    <div class="frame-chrome" aria-hidden="true">
      <span class="frame-mark"><i></i></span>
      <span class="frame-label">{label}</span>
      <span class="frame-rule"></span>
      <span class="frame-state"><i></i> Actual product</span>
    </div>
    <div class="frame-viewport">
      <Image
        src={image}
        {alt}
        loading={effectiveLoading}
        fetchpriority={priority ? 'high' : undefined}
        decoding="async"
        widths={[640, 960, 1440]}
        sizes="(min-width: 1100px) 58vw, (min-width: 720px) 92vw, 100vw"
        format="webp"
        quality={92}
      />
      <span class="frame-glint" aria-hidden="true"></span>
    </div>
  </div>
</figure>

<style>
  .product-frame {
    --frame-radius: clamp(0.75rem, 1.2vw, 1.1rem);
    container-type: inline-size;
    isolation: isolate;
    margin: 0;
    max-width: 100%;
    position: relative;
    width: 100%;
  }

  .frame-atmosphere {
    background:
      radial-gradient(circle at 76% 18%, rgb(255 112 97 / 22%), transparent 36%),
      radial-gradient(circle at 20% 80%, rgb(112 211 154 / 10%), transparent 34%);
    filter: blur(42px);
    inset: 8% 4% -8%;
    opacity: 0.82;
    pointer-events: none;
    position: absolute;
    z-index: -1;
  }

  .frame-shell {
    background: #0b0d0c;
    border: 1px solid rgb(255 255 255 / 14%);
    border-radius: var(--frame-radius);
    box-shadow:
      0 3.5rem 8rem rgb(0 0 0 / 46%),
      0 1rem 2.5rem rgb(0 0 0 / 34%),
      0 1px 0 rgb(255 255 255 / 9%) inset;
    overflow: hidden;
    position: relative;
  }

  .frame-chrome {
    align-items: center;
    background: linear-gradient(180deg, #171a18, #111412);
    border-bottom: 1px solid rgb(255 255 255 / 8%);
    color: #a8aea8;
    display: flex;
    font-size: clamp(0.5rem, 1.25cqi, 0.66rem);
    gap: 0.55rem;
    height: clamp(2rem, 5cqi, 2.65rem);
    letter-spacing: -0.01em;
    padding: 0 clamp(0.7rem, 2cqi, 1rem);
  }

  .frame-mark {
    border: 1px solid rgb(242 241 236 / 78%);
    border-radius: 0.24rem;
    height: 0.8rem;
    position: relative;
    width: 0.8rem;
  }

  .frame-mark i {
    border-bottom: 1px solid #ff7061;
    border-right: 1px solid #ff7061;
    inset: 0.2rem -0.15rem -0.15rem 0.2rem;
    position: absolute;
  }

  .frame-label {
    color: #f2f1ec;
    font-weight: 560;
  }

  .frame-rule {
    background: rgb(255 255 255 / 9%);
    height: 1px;
    margin-left: 0.2rem;
    width: 1.3rem;
  }

  .frame-state {
    align-items: center;
    color: #838b84;
    display: inline-flex;
    gap: 0.35rem;
    margin-left: auto;
  }

  .frame-state i {
    background: #70d39a;
    border-radius: 50%;
    box-shadow: 0 0 0 0.2rem rgb(112 211 154 / 8%);
    height: 0.3rem;
    width: 0.3rem;
  }

  .frame-viewport {
    background: #0e100f;
    overflow: hidden;
    position: relative;
  }

  .frame-viewport :global(img) {
    display: block;
    height: auto;
    width: 100%;
  }

  .frame-glint {
    background: linear-gradient(116deg, rgb(255 255 255 / 5%), transparent 16% 78%);
    inset: 0;
    pointer-events: none;
    position: absolute;
  }

  @media (max-width: 40rem) {
    .frame-shell {
      box-shadow:
        0 1.75rem 4rem rgb(0 0 0 / 42%),
        0 1px 0 rgb(255 255 255 / 8%) inset;
    }

    .frame-rule {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-frame,
    .frame-shell {
      transform: none !important;
    }
  }
</style>
