{
  "name": "oriel-photo",
  "version": "0.1.0",
  "private": true,
  "description": "Oriel — a fast, local-first photo workspace.",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://github.com/ralfboltshauser/oriel-photo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ralfboltshauser/oriel-photo.git"
  },
  "bugs": {
    "url": "https://github.com/ralfboltshauser/oriel-photo/issues"
  },
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=22.12 <27",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "turbo dev --filter=@oriel/desktop",
    "dev:desktop": "pnpm --filter @oriel/desktop dev",
    "dev:landing": "pnpm --filter @oriel/landing dev",
    "build": "turbo build",
    "build:desktop": "pnpm --filter @oriel/desktop build",
    "package:linux": "pnpm --filter @oriel/desktop package:linux",
    "typecheck": "turbo typecheck",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo test",
    "test:unit": "turbo test:unit",
    "test:e2e": "pnpm --filter @oriel/desktop test:e2e",
    "test:visual": "pnpm --filter @oriel/desktop test:visual",
    "test:a11y": "pnpm --filter @oriel/desktop test:a11y",
    "check:dead-code": "knip",
    "quality": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test:unit && pnpm check:dead-code"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "knip": "^5.83.1",
    "prettier": "^3.8.1",
    "turbo": "2.10.5",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.56.1"
  }
}
