{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "apps/desktop": {
      "entry": ["src/main/index.ts", "src/preload/index.ts"],
      "project": ["src/**/*.{ts,tsx}", "tests/**/*.{ts,tsx}"]
    },
    "apps/landing": {
      "entry": ["src/pages/**/*.astro"],
      "project": ["src/**/*.{astro,ts,tsx}"]
    },
    "packages/*": {
      "entry": ["src/index.{ts,tsx}"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  }
}
